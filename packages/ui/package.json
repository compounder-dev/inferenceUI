{
  "name": "@inferenceui/ui",
  "version": "0.1.0",
  "description": "Open-source UI components for compute exchanges, runtime control planes, and inference platforms. Built on shadcn primitives.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.4.0",
    "@inferenceui/tokens": "workspace:*",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2.0.0",
    "lucide-react": ">=1.0.0",
    "next": ">=14.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwind-merge": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
